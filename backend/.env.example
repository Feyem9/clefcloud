# 🌍 CONFIGURATION CLEFCLOUD

# APP
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# BASE DE DONNÉES (SUPABASE / POSTGRES)
DB_HOST=your-project-id.supabase.co
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your-password
DB_DATABASE=postgres
DB_SSL=true

# FIREBASE CONFIG (ADMIN SDK)
FIREBASE_PROJECT_ID=clefcloud-xxxxx
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@clefcloud-xxxxx.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=clefcloud-xxxxx.appspot.com

# PAYUNIT (Paiements)
PAYUNIT_API_KEY=your-payunit-api-key
PAYUNIT_USER=your-payunit-user
PAYUNIT_PASSWORD=your-payunit-password
PAYUNIT_MODE=sandbox
PAYUNIT_RETURN_URL=https://clefcloud.com/payment-success
PAYUNIT_CALLBACK_URL=https://your-backend.onrender.com/api/payments/callback
# Secret partagé avec PayUnit pour sécuriser le webhook (générer une chaîne aléatoire longue)
PAYUNIT_WEBHOOK_SECRET=change-this-to-a-long-random-secret/eed44642ba32fcf2ac984b0420689d8cc6a84d2de34d0f01251485eda83fba6b

# ADMIN
ADMIN_EMAIL=votre-email-admin@gmail.com

# EMAIL (GMAIL SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=votre-email@gmail.com
MAIL_PASSWORD=votre-mot-de-passe-application
MAIL_FROM_NAME=ClefCloud
MAIL_FROM_EMAIL=votre-email@gmail.com
